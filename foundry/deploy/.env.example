# Required secrets
OPENAI_API_KEY=sk-...
STRIPE_WEBHOOK_SECRET=whsec_...

# Required image references (private GHCR recommended)
BACKEND_IMAGE=ghcr.io/<github-owner>/foundry-backend
FRONTEND_IMAGE=ghcr.io/<github-owner>/foundry-frontend
BACKEND_IMAGE_TAG=latest
FRONTEND_IMAGE_TAG=latest

# Required runtime binary mount (host path)
LABWIRED_BINARY_PATH=/srv/labwired/bin/labwired

# Optional overrides
# COMPOSE_PROJECT_NAME=labwired-foundry
