{
  email admin@labwired.com
}

foundry.labwired.com {
  encode gzip
  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    X-Content-Type-Options "nosniff"
    X-Frame-Options "DENY"
    Referrer-Policy "strict-origin-when-cross-origin"
    Permissions-Policy "camera=(), microphone=(), geolocation=()"
    -Server
  }

  @probe path /healthz
  respond @probe 200

  @blocked path_regexp blocked (?i)(^/\.|\.env|\.git|wp-config|phpinfo|id_rsa|credentials|/storage/|/backup/)
  respond @blocked 404

  @playground path /playground*
  handle @playground {
    reverse_proxy foundry-playground:80
  }

  @api path /v1*
  handle @api {
    request_body {
      max_size 2MB
    }
    reverse_proxy foundry-backend:8080 {
      transport http {
        dial_timeout 5s
        response_header_timeout 15s
        read_timeout 30s
        write_timeout 30s
      }
    }
  }

  handle {
    reverse_proxy foundry-frontend:80
  }

  log {
    output stdout
    format console
  }
}
