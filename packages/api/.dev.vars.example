# Wrangler local development secrets — copy to .dev.vars and fill in real values.
# .dev.vars is git-ignored. NEVER commit it.
#
# For production, set these via:
#   wrangler secret put STRIPE_SECRET_KEY
#   wrangler secret put STRIPE_WEBHOOK_SECRET
#   wrangler secret put CLERK_SECRET_KEY

# Stripe restricted API key (NOT the leaked key — create a new one in Stripe dashboard)
# Minimum permissions required: read Subscriptions, read Customers
STRIPE_SECRET_KEY=sk_test_REPLACE_ME

# Stripe webhook signing secret (from Stripe dashboard → Developers → Webhooks)
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# Clerk backend secret key (https://dashboard.clerk.com → API Keys → Secret keys)
CLERK_SECRET_KEY=sk_test_REPLACE_ME

# Cloudflare DNS edit token — only needed if the Worker performs DNS
# automation at runtime. Scope: Zone → DNS → Edit on the target zone.
CF_DNS_TOKEN=REPLACE_ME

# npm publish token — only needed by automation jobs that publish from
# the Worker. ROTATE IMMEDIATELY if exposed since it can ship
# malicious package versions.
NPM_TOKEN=REPLACE_ME

# ── Build-run loop (compile + sim via labwired-builder) ──────────────────────
# Override BUILDER_URL so local dev hits a local builder instead of prod.
# wrangler.toml [vars] bakes in https://builder.labwired.com at deploy time;
# .dev.vars values take precedence during `wrangler dev`.
BUILDER_URL=http://localhost:8080
BUILDER_SECRET=dev-secret
