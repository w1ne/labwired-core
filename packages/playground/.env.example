# LabWired Playground — local dev config.
# Copy to .env.local (gitignored) to run the playground locally:
#
#   cp .env.example .env.local
#   npm install && npm run dev
#
# Then open http://localhost:5173 and click Run — no account needed.

# Skip the Clerk sign-in gate so Run/Step work without an account.
# LOCAL DEV ONLY — never set this in a deployed build.
VITE_DISABLE_AUTH=true

# Clerk publishable key. Publishable keys are public by design (they ship in
# the client bundle), so this is safe to share. Only needed if you turn auth
# back on (VITE_DISABLE_AUTH=false) to exercise the real sign-in flow.
VITE_CLERK_PUBLISHABLE_KEY=pk_live_Y2xlcmsubGFid2lyZWQuY29tJA

# Base URL for the compile/catalog API. The bundled demos run fully client-side
# (WASM), so local dev works without it; only cloud compile needs a reachable API.
VITE_LABWIRED_API_BASE=https://api.labwired.com
