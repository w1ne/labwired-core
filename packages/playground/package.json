{
  "name": "@labwired/playground",
  "version": "0.13.0",
  "private": true,
  "type": "module",
  "scripts": {
    "fetch-firmware": "bash scripts/fetch-demo-firmware.sh",
    "predev": "npm run fetch-firmware",
    "verify-production-env": "node scripts/verify-production-env.mjs",
    "prebuild": "npm run verify-production-env && npm run fetch-firmware",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run --config vitest.config.ts",
    "size": "node scripts/check-bundle-size.mjs",
    "e2e": "playwright test",
    "e2e:install": "playwright install --with-deps chromium"
  },
  "dependencies": {
    "@clerk/clerk-react": "^5.61.6",
    "@labwired/ui": "file:../ui",
    "@monaco-editor/react": "^4.7.0",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "framer-motion": "^11.18.2",
    "monaco-editor": "^0.55.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/forms": "^0.5.11",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.5.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.14",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.3",
    "vite": "^6.3.5",
    "vitest": "^4.0.18"
  }
}
