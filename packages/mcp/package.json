{
  "name": "@labwired/mcp",
  "version": "0.5.0",
  "description": "Model Context Protocol server exposing the LabWired deterministic firmware simulator as agent tools.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "labwired-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "npm --prefix ../board-config run build && tsc",
    "dev": "tsx src/index.ts",
    "pretest": "npm run build",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@labwired/board-config": "file:../board-config",
    "@modelcontextprotocol/sdk": "^1.20.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.20.0",
    "typescript": "~5.9.3",
    "vitest": "~3.2.0"
  },
  "engines": {
    "node": ">=20"
  }
}
