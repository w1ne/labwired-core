{
  "name": "@labwired/board-config",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.mjs --packages=external && cp dist/index.mjs dist/index.js",
    "generate:boards": "node scripts/generate-playground-board-catalog.mjs",
    "check:boards": "node scripts/generate-playground-board-catalog.mjs --check",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "typescript": "~5.9.3",
    "vitest": "~3.2.0"
  }
}
