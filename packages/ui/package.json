{
  "name": "@labwired/ui",
  "version": "0.20.0",
  "type": "module",
  "main": "./dist/labwired-ui.js",
  "module": "./dist/labwired-ui.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/labwired-ui.js",
      "types": "./dist/index.d.ts"
    },
    "./tokens.css": "./src/tokens/design-tokens.css",
    "./inspector.css": "./src/editor/inspector.css"
  },
  "files": [
    "dist",
    "src/tokens/design-tokens.css",
    "src/editor/inspector.css"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "npm --prefix ../board-config run build && tsc -b && vite build",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.1.1",
    "jsdom": "^27.4.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "typescript": "~5.9.3",
    "vite": "^6.3.5",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.0"
  },
  "dependencies": {
    "@labwired/board-config": "file:../board-config",
    "@monaco-editor/react": "^4.7.0",
    "monaco-editor": "^0.55.1"
